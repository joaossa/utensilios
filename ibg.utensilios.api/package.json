{
  "name": "ibg.utensilios.api",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "postinstall": "node hostinger-stage.js postinstall",
    "build": "node hostinger-stage.js build",
    "build:ts": "tsc -p tsconfig.json",
    "build:hostinger": "npm run build",
    "postbuild": "node hostinger-stage.js postbuild",
    "prestart": "node hostinger-stage.js prestart",
    "start": "node hostinger-stage.js start && node index.js",
    "db:ensure-public-schema": "node db/scripts/ensure-public-schema.js",
    "db:migrate": "npm run db:ensure-public-schema && knex migrate:latest --knexfile knexfile.js",
    "db:rollback": "npm run db:ensure-public-schema && knex migrate:rollback --knexfile knexfile.js",
    "db:make": "knex migrate:make --knexfile knexfile.js",
    "db:seed": "npm run db:ensure-public-schema && tsx db/seeds/seed.ts",
    "db:seed:item-lookups": "npm run db:ensure-public-schema && tsx db/seeds/seed-item-lookups.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.16.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
